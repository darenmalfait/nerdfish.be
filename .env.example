NEXT_PUBLIC_URL=http://localhost:3000

# Recaptcha (optional, if not set, recaptcha will not be used)
NEXT_PUBLIC_RECAPTCHA_SITEKEY=***
RECAPTCHA_SECRETKEY=***

# Email settings
EMAIL_FROM=Example from Company <example@company.com>
RESEND_API_KEY=***


## Clerk (optional — omit both keys to run without authentication)
# CLERK_SECRET_KEY=sk_***
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_***
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=http://localhost:3000/app/sign-in
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=http://localhost:3000/app

